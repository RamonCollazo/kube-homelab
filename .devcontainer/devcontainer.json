{
  "name": "Kube Homelab",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "vscode",
  "containerUser": "vscode",
  "postCreateCommand": "sudo chown -R vscode:vscode /home/vscode/.local && mise trust && mise install",
  "mounts": [
    "source=mise-data,target=/home/vscode/.local/share/mise,type=volume",
    "source=mise-state,target=/home/vscode/.local/state/mise,type=volume"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "redhat.vscode-yaml"
      ]
    }
  }
}
