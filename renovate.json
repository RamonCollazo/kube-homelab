{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "ignorePaths": [
    "clusters/**"
  ],
  "kubernetes": {
    "managerFilePatterns": [
      "/(^|/)deployment\\.ya?ml$/",
      "/(^|/)statefulset\\.ya?ml$/",
      "/(^|/)daemonset\\.ya?ml$/",
      "/(^|/)cronjob\\.ya?ml$/"
    ]
  },
  "flux": {
    "managerFilePatterns": [
      "/(^|/)apps/base/.+\\.ya?ml$/",
      "/(^|/)infrastructure/controllers/base/.+\\.ya?ml$/",
      "/(^|/)monitoring/controllers/base/.+\\.ya?ml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)apps/base/hermes/instance\\.ya?ml$/"
      ],
      "matchStrings": [
        "repository:\\s*(?<depName>\\S+)\\s+tag:\\s*[\"']?(?<currentValue>[^\"'\\s]+)[\"']?"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "description": "Authentik uses CalVer (YYYY.MM.MICRO)",
      "matchPackageNames": [
        "authentik"
      ],
      "versioning": "calver:YYYY.MM.MICRO"
    },
    {
      "description": "hermes-agent uses CalVer (vYYYY.M.D[.PATCH])",
      "matchPackageNames": [
        "ghcr.io/paperclipinc/hermes-agent"
      ],
      "versioning": "regex:^v?(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)(?:\\.(?<build>\\d+))?$"
    },
    {
      "description": "Group rook-ceph operator and cluster chart upgrades together",
      "groupName": "rook-ceph",
      "matchPackageNames": [
        "rook-ceph",
        "rook-ceph-cluster"
      ]
    },
    {
      "description": "Ignore OCI packages from Codeberg (not supported by Renovate)",
      "matchPackageNames": [
        "codeberg.org/forgejo-contrib/forgejo",
        "codeberg.org/wrenix/helm-charts/grampsweb"
      ],
      "enabled": false
    }
  ]
}
